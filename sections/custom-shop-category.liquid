<div class="shop-category-section">

  <div class="page-width">

    {% if section.settings.heading != blank %}
      <h2 class="shop-category-title">
        {{ section.settings.heading }}
      </h2>
    {% endif %}


    <div class="shop-category-grid">

      {% for block in section.blocks %}

        {% assign col = block.settings.collection %}

        {% if col != blank %}

          <div class="shop-category-item" {{ block.shopify_attributes }}>

            <a href="{{ col.url }}" class="shop-category-link">

              <div class="shop-category-image">

                {% if col.image %}
                  {{
                    col.image
                    | image_url: width: 800
                    | image_tag: loading: 'lazy'
                  }}
                {% else %}
                  {{
                    col.products.first.featured_image
                    | image_url: width: 800
                    | image_tag: loading: 'lazy'
                  }}
                {% endif %}

              </div>


              <div class="shop-category-overlay">

                <h3 class="shop-category-name">
                  {{ col.title }}
                </h3>

                {% if block.settings.button != blank %}
                  <span class="shop-category-btn">
                    {{ block.settings.button }}
                  </span>
                {% endif %}

              </div>

            </a>

          </div>

        {% endif %}

      {% endfor %}

    </div>

  </div>

</div>



{% schema %}
{
  "name": "Shop by category",

  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SHOP BY CATEGORY"
    }
  ],

  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Select collection"
        },
        {
          "type": "text",
          "id": "button",
          "label": "Button text",
          "default": "SHOP NOW"
        }
      ]
    }
  ],

  "max_blocks": 8,

  "presets": [
    {
      "name": "Shop by category"
    }
  ]
}
{% endschema %}